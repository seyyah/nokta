{
  "expo": {
    "name": "Idea Tracker",
    "slug": "idea-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "idea-tracker",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sibel464.ideatracker"
    },

    "android": {
      "package": "com.sibel464.ideatracker",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1e1b4b"
      }
    },

    "web": {
      "favicon": "./assets/images/icon.png"
    },

    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],

    "extra": {
      "router": {},
      "eas": {
        "projectId": "7c914684-720f-4c5f-a75f-0b5e93f13fcd"
      }
    },

    "owner": "sibel464"
  }
}